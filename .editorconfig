root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown: two trailing spaces are a hard line break — don't strip them.
[*.md]
trim_trailing_whitespace = false

# .NET sources (when code lands)
[*.{cs,csx}]
indent_style = space
indent_size = 2

[*.{yml,yaml,json,jsonc}]
indent_size = 2

[Makefile]
indent_style = tab
